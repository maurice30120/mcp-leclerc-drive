{
  "name": "mcp-leclerc-drive",
  "version": "1.0.0",
  "mcpName": "io.github.maurice30120/leclerc-drive",
  "description": "Expose your Leclerc Drive as MCP tools via WebMCP — search products, manage cart, refresh natively, from any MCP client (opencode / Claude Code).",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:extension": "node scripts/build-extension.mjs",
    "build:all": "npm run build && npm run build:extension",
    "fetch:model": "node scripts/fetch-model.mjs",
    "dev": "tsc --watch",
    "mobile:start": "npm --prefix drive-assistant-mobile start",
    "mobile:ios": "npm --prefix drive-assistant-mobile run ios --",
    "mobile:android": "npm --prefix drive-assistant-mobile run android --",
    "mobile:typecheck": "npm --prefix drive-assistant-mobile run typecheck",
    "mobile:test": "npm --prefix drive-assistant-mobile test",
    "test": "node --test tests/*.test.ts",
    "test:inference": "MCP_LECLERC_RUN_INFERENCE=1 node --test tests/model-inference.test.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.extension.json",
    "clean": "node scripts/clean.mjs --keep-models",
    "clean:dry": "node scripts/clean.mjs --dry-run",
    "clean:all": "node scripts/clean.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "webmcp",
    "mcp-b",
    "opencode",
    "leclerc",
    "leclerc-drive",
    "grocery",
    "courses"
  ],
  "author": "maurice30120",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maurice30120/mcp-leclerc-drive.git"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@mcp-b/global": "^3.0.0",
    "@mcp-b/webmcp-types": "^3.0.0"
  },
  "devDependencies": {
    "@mcp-b/webmcp-local-relay": "^3.0.0",
    "@types/chrome": "^0.2.2",
    "@types/node": "^22.0.0",
    "cli-progress": "^3.12.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.6.0"
  }
}
