{
  "name": "mcp-leclerc-drive",
  "version": "1.0.0",
  "mcpName": "io.github.skunkobi/leclerc-drive",
  "description": "Expose your Leclerc Drive as MCP tools via WebMCP — search products, manage cart, refresh natively, from any MCP client (opencode / Claude Code).",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:extension": "node scripts/build-extension.mjs",
    "build:all": "npm run build && npm run build:extension",
    "dev": "tsc --watch",
    "test": "node --test tests/*.test.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.extension.json",
    "clean": "rm -rf dist dist-extension-types"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "webmcp",
    "mcp-b",
    "opencode",
    "leclerc",
    "leclerc-drive",
    "grocery",
    "courses"
  ],
  "author": "skunkobi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skunkobi/mcp-leclerc-drive.git"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@mcp-b/global": "^3.0.0",
    "@mcp-b/webmcp-types": "^3.0.0"
  },
  "devDependencies": {
    "@mcp-b/webmcp-local-relay": "^3.0.0",
    "@types/chrome": "^0.2.2",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.6.0"
  }
}