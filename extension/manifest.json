{
  "manifest_version": 3,
  "name": "mcp-leclerc-drive",
  "version": "{{EXTENSION_VERSION}}",
  "description": "Expose Leclerc Drive as MCP tools via WebMCP (for opencode / Claude Code).",
  "permissions": ["scripting", "activeTab", "storage"],
  "host_permissions": ["*://*.leclercdrive.fr/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "mcp-leclerc-drive"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["inject.js", "embed.js"],
      "matches": ["*://*.leclercdrive.fr/*"]
    }
  ]
}